# PostgreSQL connection string
# Lokálně: postgresql://user:heslo@localhost:5432/planner
# Render.com: vyplní se automaticky z render.yaml
DATABASE_URL=postgresql://user:heslo@localhost:5432/planner

# Admin přístupový token – změňte na silné heslo
ADMIN_TOKEN=change_me_please

# Číslo bankovního účtu ve formátu IBAN (zobrazí se účastníkům po přihlášení)
BANK_ACCOUNT=CZ00 0000 0000 0000 0000 0000

# Port (Render.com nastavuje automaticky, lokálně volitelné)
PORT=8000
